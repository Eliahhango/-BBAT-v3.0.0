{
  "description": "BBAT default configuration",
  "project": {
    "name": "BugBountyToolkit",
    "version": "3.0.0",
    "author": "Security Researcher",
    "output_dir": "./output"
  },
  "recon": {
    "wordlist": "./wordlists/common.txt",
    "threads": 50,
    "timeout": 10,
    "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "resolvers": ["8.8.8.8", "1.1.1.1"],
    "port_scan": {
      "top_ports": 1000,
      "rate_limit": 1000
    }
  },
  "scanner": {
    "templates_dir": "./templates",
    "severity_levels": ["critical", "high", "medium", "low", "info"]
  },
  "fuzzer": {
    "extensions": ["txt", "bak", "old", "zip", "tar.gz"],
    "methods": ["GET", "POST"],
    "threads": 100
  },
  "crawler": {
    "max_depth": 3,
    "max_pages": 500,
    "same_domain_only": true,
    "respect_robots": true
  },
  "takeover": {
    "verify": true,
    "check_http": true
  },
  "js_analyzer": {
    "max_file_size_kb": 5000,
    "timeout": 15
  },
  "fingerprint": {
    "timeout": 15,
    "check_multiple_paths": true
  },
  "ctlog": {
    "timeout": 30,
    "include_expired": false
  },
  "notifier": {
    "slack_webhook": "",
    "discord_webhook": "",
    "notify_on": ["high", "critical"]
  },
  "wayback": {
    "timeout": 60,
    "match_subdomains": true
  },
  "s3_scanner": {
    "region": "us-east-1",
    "timeout": 10
  },
  "git_scanner": {
    "timeout": 10
  },
  "paramfinder": {
    "timeout": 10,
    "max_params_per_url": 20
  },
  "nuclei": {
    "templates_dir": "",
    "severity": "critical,high,medium,low,info",
    "rate_limit": 150,
    "timeout": 10,
    "concurrency": 25,
    "headless": false
  },
  "screenshot": {
    "timeout": 30,
    "resolution": "1920x1080",
    "output_dir": "./output/screenshots",
    "backend": "auto"
  },
  "waf_detector": {
    "timeout": 10
  },
  "api_fuzzer": {
    "timeout": 10,
    "idor_test": true,
    "method_fuzz": true
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 5000
  },
  "async_engine": {
    "concurrency": 100,
    "timeout": 10
  },
  "reporting": {
    "formats": ["json", "markdown", "html"],
    "auto_save": true
  }
}
